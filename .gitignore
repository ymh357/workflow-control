node_modules/
dist/
.next/
.env
.env.local
*.tsbuildinfo
.DS_Store
coverage/

# Registry generated artifacts (rebuild with `pnpm --filter server registry:build`)
registry/packages/
registry/index.json

# System settings (contains secrets — use system-settings.yaml.example as template)
apps/server/config/system-settings.yaml

# Root-level config/ (local workflow configuration, not committed)
/config/

# config/ managed by registry (use `pnpm registry bootstrap` after clone)
apps/server/config/pipelines/
apps/server/config/skills/
apps/server/config/hooks/
apps/server/config/prompts/
apps/server/config/gates/
apps/server/config/scripts/
apps/server/.wfctl-registry.lock
apps/server/.publish-tmp/

# Agent-generated stray prompt files (refinePrompts may write to wrong paths)
apps/server/prompts/
apps/server/src/pipelines/
apps/server/src/prompts/
apps/server/src/system-prompts/

# Claude Code runtime artifacts (worktrees, reports) — settings and agents are tracked
.claude/worktrees/
.claude/full-review-report.md

# Per-app local Claude settings (user-specific hooks, not shared)
apps/*/.claude/

# Playwright generated output
apps/web/e2e/test-results/
apps/web/playwright-report/

# Playwright MCP screenshots
.playwright-mcp/

# Local MCP config backup
.mcp.json.bak

# Local SQLite databases (kernel-next runtime DB, created by tests / runs)
apps/server/kernel-next.db
apps/server/kernel-next.db-*
apps/server/workflow.db
apps/server/workflow.db-*

# Scratch images / screenshots
/*.png

# Root-level test output
/test-results/

# Script-produced scratch artifacts in app roots (e.g.
# persist_pipeline's deliverable-write error report written by a
# running tech-research-writer task). These are per-run outputs, not
# source.
apps/*/.deliverable-error.md

# Per-app runtime output directories from pipeline runs (e.g.
# pipeline-generator's persist_pipeline writes a deliverable-error.txt
# here when a downstream write fails). Not source.
apps/*/.workflow/

# P6-3: when the server is launched from the monorepo root (rather
# than apps/server/), pipeline agents write the same reportPath
# relative to that cwd — so .workflow/ may appear here too. Per-task
# workspace isolation (Phase 5C worktree hookup) will make this
# redundant later.
/.workflow/

# Team env (shared secrets — use .env.team.example as template)
.env.team

# User-specific config (these are registry-managed; only global.md and stage/ are tracked)
apps/server/config/claude-md/*.md
!apps/server/config/claude-md/global.md
apps/server/config/system-prompts/
apps/server/config/claude-commands/
