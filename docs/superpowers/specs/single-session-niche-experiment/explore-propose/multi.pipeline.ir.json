{
  "name": "niche-exp-explore-propose-multi",
  "session_mode": "multi",
  "externalInputs": [
    { "name": "repoPath", "type": "string" },
    { "name": "refactorGoal", "type": "string" }
  ],
  "stages": [
    {
      "name": "exploreCodebase",
      "type": "agent",
      "config": { "promptRef": "system/explorer" },
      "inputs": [
        { "name": "repoPath", "type": "string" },
        { "name": "refactorGoal", "type": "string" }
      ],
      "outputs": [
        { "name": "filesConsidered", "type": "string[]" },
        { "name": "filesRuledOut", "type": "{ path: string; reason: string }[]" },
        { "name": "couplingObservations", "type": "string[]" },
        { "name": "summary", "type": "string" }
      ]
    },
    {
      "name": "proposeRefactor",
      "type": "agent",
      "config": { "promptRef": "system/proposer" },
      "inputs": [
        { "name": "refactorGoal", "type": "string" },
        { "name": "filesConsidered", "type": "string[]" },
        { "name": "filesRuledOut", "type": "{ path: string; reason: string }[]" },
        { "name": "couplingObservations", "type": "string[]" },
        { "name": "explorerSummary", "type": "string" }
      ],
      "outputs": [
        { "name": "proposalMarkdown", "type": "string" }
      ]
    }
  ],
  "wires": [
    { "from": { "source": "external", "port": "repoPath" }, "to": { "stage": "exploreCodebase", "port": "repoPath" } },
    { "from": { "source": "external", "port": "refactorGoal" }, "to": { "stage": "exploreCodebase", "port": "refactorGoal" } },
    { "from": { "source": "external", "port": "refactorGoal" }, "to": { "stage": "proposeRefactor", "port": "refactorGoal" } },
    { "from": { "source": "stage", "stage": "exploreCodebase", "port": "filesConsidered" }, "to": { "stage": "proposeRefactor", "port": "filesConsidered" } },
    { "from": { "source": "stage", "stage": "exploreCodebase", "port": "filesRuledOut" }, "to": { "stage": "proposeRefactor", "port": "filesRuledOut" } },
    { "from": { "source": "stage", "stage": "exploreCodebase", "port": "couplingObservations" }, "to": { "stage": "proposeRefactor", "port": "couplingObservations" } },
    { "from": { "source": "stage", "stage": "exploreCodebase", "port": "summary" }, "to": { "stage": "proposeRefactor", "port": "explorerSummary" } }
  ]
}
