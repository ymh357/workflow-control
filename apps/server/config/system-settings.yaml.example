# System Settings — copy to system-settings.yaml and fill in real values
# Supports ${ENV_VAR} interpolation (reads from process.env at runtime)

paths:
  repos_base: ${HOME}
  worktrees_base: ${HOME}/worktrees
  data_dir: /tmp/workflow-control-data
  claude_executable: claude
  gemini_executable: gemini
  codex_executable: codex
agent:
  default_model: claude-sonnet-4-6
  claude_model: claude-sonnet-4-6
  gemini_model: auto
  codex_model: ""
  default_engine: claude
  max_budget_usd: 10
notion:
  sprint_board_id: ""
  ds_id: ""
github:
  org: ""
figma:
  access_token: ""
sandbox:
  enabled: false
  auto_allow_bash: true
  allow_unsandboxed_commands: true
  network:
    allowed_domains: []
  filesystem:
    allow_write: []
    deny_write: []
    deny_read: []
