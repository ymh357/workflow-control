{
  "externalInputs": [
    {
      "name": "pipelineConfig",
      "type": "unknown"
    },
    {
      "name": "projectContext",
      "type": "unknown"
    }
  ],
  "name": "Tech Research Collector",
  "stages": [
    {
      "config": {
        "promptRef": "system/collect-target-sources"
      },
      "inputs": [
        {
          "name": "pipelineConfig",
          "type": "unknown"
        },
        {
          "name": "projectContext",
          "type": "unknown"
        }
      ],
      "name": "collectTargetSources",
      "outputs": [
        {
          "name": "extractedFacts",
          "type": "string[]"
        },
        {
          "name": "officialSourceCount",
          "type": "number"
        },
        {
          "name": "reportPath",
          "type": "string"
        },
        {
          "name": "sourceCatalog",
          "type": "string[]"
        },
        {
          "name": "spaWarnings",
          "type": "string[]"
        },
        {
          "name": "subjectType",
          "type": "string"
        },
        {
          "name": "summary",
          "type": "string"
        },
        {
          "name": "targetName",
          "type": "string"
        }
      ],
      "type": "agent"
    }
  ],
  "wires": [
    {
      "from": {
        "port": "pipelineConfig",
        "source": "external"
      },
      "to": {
        "port": "pipelineConfig",
        "stage": "collectTargetSources"
      }
    },
    {
      "from": {
        "port": "projectContext",
        "source": "external"
      },
      "to": {
        "port": "projectContext",
        "stage": "collectTargetSources"
      }
    }
  ],
  "store_schema": {
    "collectTargetSources.extractedFacts": {
      "type": "string[]",
      "description": "extractedFacts emitted by collectTargetSources stage.",
      "produced_by": {
        "stage": "collectTargetSources",
        "port": "extractedFacts"
      }
    },
    "collectTargetSources.officialSourceCount": {
      "type": "number",
      "description": "officialSourceCount emitted by collectTargetSources stage.",
      "produced_by": {
        "stage": "collectTargetSources",
        "port": "officialSourceCount"
      }
    },
    "collectTargetSources.reportPath": {
      "type": "string",
      "description": "reportPath emitted by collectTargetSources stage.",
      "produced_by": {
        "stage": "collectTargetSources",
        "port": "reportPath"
      }
    },
    "collectTargetSources.sourceCatalog": {
      "type": "string[]",
      "description": "sourceCatalog emitted by collectTargetSources stage.",
      "produced_by": {
        "stage": "collectTargetSources",
        "port": "sourceCatalog"
      }
    },
    "collectTargetSources.spaWarnings": {
      "type": "string[]",
      "description": "spaWarnings emitted by collectTargetSources stage.",
      "produced_by": {
        "stage": "collectTargetSources",
        "port": "spaWarnings"
      }
    },
    "collectTargetSources.subjectType": {
      "type": "string",
      "description": "subjectType emitted by collectTargetSources stage.",
      "produced_by": {
        "stage": "collectTargetSources",
        "port": "subjectType"
      }
    },
    "collectTargetSources.summary": {
      "type": "string",
      "description": "summary emitted by collectTargetSources stage.",
      "produced_by": {
        "stage": "collectTargetSources",
        "port": "summary"
      }
    },
    "collectTargetSources.targetName": {
      "type": "string",
      "description": "targetName emitted by collectTargetSources stage.",
      "produced_by": {
        "stage": "collectTargetSources",
        "port": "targetName"
      }
    }
  }
}
