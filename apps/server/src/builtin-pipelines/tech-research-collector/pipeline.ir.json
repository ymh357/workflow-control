        },
        {
          "name": "reportPath",
          "type": "string"
        },
        {
          "name": "sourceCatalog",
          "type": "string[]"
        },
        {
          "name": "spaWarnings",
          "type": "string[]"
        },
        {
          "name": "subjectType",
          "type": "string"
        },
        {
          "name": "summary",
          "type": "string"
        },
        {
          "name": "targetName",
          "type": "string"
        }
