{
  "name": "smoke-test",
  "stages": [
    {
      "config": {
        "promptRef": "system/echo-back"
      },
      "inputs": [
        {
          "name": "note",
          "type": "string"
        },
        {
          "name": "subject",
          "type": "string"
        }
      ],
      "name": "echoBack",
      "outputs": [
        {
          "name": "message",
          "type": "string"
        }
      ],
      "type": "agent"
    },
    {
      "config": {
        "promptRef": "system/greet"
      },
      "inputs": [],
      "name": "greet",
      "outputs": [
        {
          "name": "note",
          "type": "string"
        },
        {
          "name": "subject",
          "type": "string"
        }
      ],
      "type": "agent"
    }
  ],
  "wires": [
    {
      "from": {
        "port": "note",
        "stage": "greet"
      },
      "to": {
        "port": "note",
        "stage": "echoBack"
      }
    },
    {
      "from": {
        "port": "subject",
        "stage": "greet"
      },
      "to": {
        "port": "subject",
        "stage": "echoBack"
      }
    }
  ],
  "store_schema": {
    "greet.note": {
      "type": "string",
      "description": "Short note produced by greet stage, consumed by echoBack.",
      "produced_by": {
        "stage": "greet",
        "port": "note"
      }
    },
    "greet.subject": {
      "type": "string",
      "description": "Subject line produced by greet stage, consumed by echoBack.",
      "produced_by": {
        "stage": "greet",
        "port": "subject"
      }
    },
    "echoBack.message": {
      "type": "string",
      "description": "Final echoed message combining the note + subject.",
      "produced_by": {
        "stage": "echoBack",
        "port": "message"
      }
    }
  }
}
