# ============================================================
# workflow-control local config (gitignored, per-developer)
# Copy to .env.local and edit as needed.
#
# This file is for SERVER-PROCESS variables only. Per-task MCP
# secrets (API tokens, OAuth credentials) belong in the encrypted
# MCP catalog — manage them via the dashboard at
# /kernel-next/mcp-catalog or the `add_mcp_catalog_entry` MCP
# tool. Putting them here would leak them into ps output and
# every shell that inherits the environment.
# ============================================================

# Claude CLI path. Auto-detected from $PATH; override only if you
# have multiple installs and want to pin one.
# CLAUDE_PATH=/usr/local/bin/claude

# Persistent data directory. Defaults to /tmp/workflow-control-data
# which is volatile on macOS reboot. Set to a real path for any
# non-throwaway use.
# DATA_DIR=/Users/yourname/.workflow-control

# Logging. Default is "info"; "debug" enables verbose runner /
# real-executor traces.
# LOG_LEVEL=debug
