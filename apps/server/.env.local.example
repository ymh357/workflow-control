# ============================================================
# workflow-control local config (gitignored, per-developer)
# Copy to .env.local and fill in your values.
# ============================================================

# Claude Code executable (auto-detected if on PATH)
CLAUDE_PATH=/usr/local/bin/claude

# Base directory where your git repos live
REPOS_BASE_PATH=/Users/yourname/projects

# Directory for git worktrees (created automatically)
WORKTREES_BASE_PATH=/Users/yourname/worktrees

# ============================================================
# CORE FRAMEWORK SETTINGS (Required by Preflight)
# ============================================================

# Slack configuration for task notifications
SETTING_SLACK_BOT_TOKEN=xoxb-xxx
SETTING_SLACK_NOTIFY_CHANNEL_ID=C0xxx

# ============================================================
# OPTIONAL FEATURE SETTINGS (Optional in Preflight)
# ============================================================

# Notion Integration token (Used if local settings mapping is preferred)
# SETTING_NOTION_TOKEN=ntn_xxx

# Figma access token (for design context extraction)
SETTING_FIGMA_ACCESS_TOKEN=figd_xxx

# Slack signing secret (only needed if using interactive Slack commands)
# SETTING_SLACK_SIGNING_SECRET=xxx

# ============================================================
# SCRIPT INTEGRATIONS (Optional)
# ============================================================

# VERCEL SETTINGS
# VERCEL_PROJECT_ID=prj_xxx
# VERCEL_TEAM_ID=team_xxx
# VERCEL_WEBHOOK_SECRET=whsec_xxx

# GITHUB SETTINGS
# GITHUB_WEBHOOK_SECRET=your_secret
