{
  "name": "server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "setup": "tsx src/setup.ts",
    "preflight": "tsx src/scripts/preflight-run.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "edge": "tsx src/edge/runner.ts",
    "registry": "tsx src/cli/registry.ts",
    "registry:gen": "tsx ../../registry/generate-manifests.ts",
    "registry:index": "tsx ../../registry/build-index.ts",
    "registry:build": "tsx ../../registry/generate-manifests.ts && tsx ../../registry/build-index.ts",
    "registry:bootstrap": "tsx src/cli/registry.ts bootstrap",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true"
  },
  "bin": {
    "wfctl-edge": "src/edge/runner.ts",
    "wfctl": "src/cli/registry.ts"
  },
  "dependencies": {
    "@workflow-control/shared": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@slack/bolt": "^4.6.0",
    "expr-eval": "^2.0.2",
    "hono": "^4.12.3",
    "node-pty": "^1.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "xstate": "^5.28.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  }
}
